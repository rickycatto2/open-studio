---
const COLS = 16;
const ROWS = 12;

// Keep the wall deterministic so it doesn't reshuffle every refresh.
function seededRandom(seed: number) {
  let value = seed % 2147483647;
  if (value <= 0) value += 2147483646;
  return () => {
    value = (value * 16807) % 2147483647;
    return (value - 1) / 2147483646;
  };
}

const rand = seededRandom(424242);

type BrickCell = {
  id: string;
  col: number;
  row: number;
  type: "base" | "dark" | "eyes";
};

const eyePositions = new Set<string>();
while (eyePositions.size < 2) {
  const col = Math.floor(rand() * COLS);
  const row = Math.floor(rand() * ROWS);
  if (row > 1) {
    eyePositions.add(`${col}-${row}`);
  }
}

const cells: BrickCell[] = [];

for (let row = 0; row < ROWS; row++) {
  for (let col = 0; col < COLS; col++) {
    const key = `${col}-${row}`;

    let type: BrickCell["type"] = "base";

    if (eyePositions.has(key)) {
      type = "eyes";
    } else {
      // About 3% dark bricks
      if (rand() < 0.03) type = "dark";
    }

    cells.push({
      id: key,
      col,
      row,
      type
    });
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Brick Test</title>
  </head>
  <body>
    <section class="brick-test-page">
      <div class="wall-copy">
        <h2>Brick Wall Test</h2>
        <p>Proof of concept for the Stockyards wall background.</p>
      </div>

      <div class="brick-wall-grid" aria-hidden="true">
        {cells.map((cell, index) => (
          <div
            class={`brick-cell ${cell.type}`}
            style={`--col:${cell.col}; --row:${cell.row};`}
          >
            {cell.type === "eyes" ? (
              <div class={`eye-brick ${index % 2 === 0 ? "eye-brick-a" : "eye-brick-b"}`}>
                <div class="eye left-eye eye-a">
                  <div class="pupil pupil-a"></div>
                </div>
                <div class="eye right-eye eye-b">
                  <div class="pupil pupil-b"></div>
                </div>
              </div>
            ) : (
              <img
                src={cell.type === "dark" ? "/assets/dark-brick.svg" : "/assets/brick-base.svg"}
                alt=""
                class="brick-svg"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        ))}
      </div>
    </section>
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    min-height: 100%;
  }

  body {
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }
</style>

<style>
  .brick-test-page {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    overflow: hidden;
    background: #E4A8CB;
  }

  .wall-copy {
    position: relative;
    z-index: 20;
    padding: 24px;
    color: white;
    text-shadow: 0 2px 10px rgba(0,0,0,0.25);
    max-width: 42rem;
  }

  .wall-copy h2 {
    margin: 0 0 8px;
  }

  .wall-copy p {
    margin: 0;
  }

  .brick-wall-grid {
    position: relative;
    z-index: 5;
    min-height: 100vh;
    width: 100%;
    padding: 24px 0 40px;
  }

  .brick-cell {
    position: absolute;
    width: 84px;
    height: 56px;
    left: calc(var(--col) * 84px);
    top: calc(var(--row) * 56px);
  }

  .brick-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .eye-brick {
    position: relative;
    width: 100%;
    height: 100%;
    background-image: url("/assets/dark-brick.svg");
    background-size: 100% 100%;
    background-repeat: no-repeat;
    background-position: center;
  }

  .eye {
    position: absolute;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ef654e;
    overflow: hidden;
    transform-origin: center center;
    z-index: 2;
  }

  .left-eye {
    left: 25px;
  }

  .right-eye {
    left: 45px;
  }

  .pupil {
    position: absolute;
    width: 7px;
    height: 7px;
    left: 4px;
    top: 4px;
    border-radius: 50%;
    background: #8e382d;
  }

  /* Base animations for one eye set */
  .eye-a {
    animation: blink-a 8.7s infinite;
  }

  .eye-b {
    animation: blink-b 11.4s infinite;
  }

  .pupil-a {
    animation: look-a 9.6s infinite ease-in-out;
  }

  .pupil-b {
    animation: look-b 12.1s infinite ease-in-out;
  }

  /* Delay the second eye-brick set so they don't act in sync */
  .eye-brick-b .eye-a {
    animation-delay: 2.2s;
  }

  .eye-brick-b .eye-b {
    animation-delay: 3.4s;
  }

  .eye-brick-b .pupil-a {
    animation-delay: 4.1s;
  }

  .eye-brick-b .pupil-b {
    animation-delay: 5.3s;
  }

  @keyframes look-a {
    0%   { transform: translate(0px, 0px); }
    10%  { transform: translate(0px, 0px); }
    15%  { transform: translate(2px, -1px); }
    23%  { transform: translate(2px, -1px); }
    28%  { transform: translate(0px, 0px); }

    46%  { transform: translate(0px, 0px); }
    52%  { transform: translate(-2px, 1px); }
    61%  { transform: translate(-2px, 1px); }
    66%  { transform: translate(0px, 0px); }

    82%  { transform: translate(0px, 0px); }
    88%  { transform: translate(1px, 2px); }
    94%  { transform: translate(1px, 2px); }
    100% { transform: translate(0px, 0px); }
  }

  @keyframes look-b {
    0%   { transform: translate(0px, 0px); }
    18%  { transform: translate(0px, 0px); }
    24%  { transform: translate(1px, -1px); }
    31%  { transform: translate(1px, -1px); }
    36%  { transform: translate(0px, 0px); }

    54%  { transform: translate(0px, 0px); }
    60%  { transform: translate(-1px, 2px); }
    69%  { transform: translate(-1px, 2px); }
    74%  { transform: translate(0px, 0px); }

    88%  { transform: translate(0px, 0px); }
    93%  { transform: translate(2px, 0px); }
    97%  { transform: translate(2px, 0px); }
    100% { transform: translate(0px, 0px); }
  }

  @keyframes blink-a {
    0%, 47%, 49%, 83%, 85%, 100% {
      transform: scaleY(1);
    }
    48%, 84% {
      transform: scaleY(0.08);
    }
  }

  @keyframes blink-b {
    0%, 28%, 30%, 72%, 74%, 100% {
      transform: scaleY(1);
    }
    29%, 73% {
      transform: scaleY(0.08);
    }
  }

  @media (max-width: 1100px) {
    .brick-cell {
      width: 72px;
      height: 48px;
      left: calc(var(--col) * 72px);
      top: calc(var(--row) * 48px);
    }

    .eye {
      top: 5px;
      width: 14px;
      height: 14px;
    }

    .left-eye { left: 22px; }
    .right-eye { left: 39px; }

    .pupil {
      width: 6px;
      height: 6px;
      left: 4px;
      top: 4px;
    }
  }

  @media (max-width: 800px) {
    .brick-cell {
      width: 56px;
      height: 37.33px;
      left: calc(var(--col) * 56px);
      top: calc(var(--row) * 37.33px);
    }

    .eye {
      top: 4px;
      width: 11px;
      height: 11px;
    }

    .left-eye { left: 17px; }
    .right-eye { left: 30px; }

    .pupil {
      width: 5px;
      height: 5px;
      left: 3px;
      top: 3px;
    }
  }
</style>