---
import BrickWall from "../components/BrickWall.astro";
import rawArtists from "../data/artists.json";

type Artist = {
  id: string;
  additional_info?: string;
  studioNumber: number | string;
  display_name: string;
  social_label?: string;
  website?: string;
  art_type?: string;
  image: string;
  thumbs: string;
};

const artists = (rawArtists as Artist[])
  .map((artist) => ({
    id: String(artist.id),
    displayName: artist.display_name?.trim() ?? "",
    additionalInfo: artist.additional_info?.trim() ?? "",
    studioNumber: Number(artist.studioNumber),
    artType: artist.art_type?.replace(/\s+/g, " ").trim() ?? "",
    image: artist.image,
    thumb: artist.thumbs,
    socialLabel: artist.social_label?.trim() ?? "",
    website: artist.website?.trim() ?? "",
    searchText: [
      artist.display_name,
      artist.additional_info,
      artist.art_type,
      artist.studioNumber,
      artist.social_label
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase()
  }))
  .sort((a, b) => {
    if (a.studioNumber !== b.studioNumber) {
      return a.studioNumber - b.studioNumber;
    }
    return a.displayName.localeCompare(b.displayName);
  });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Artists • Open Studios</title>
  </head>

  <body>
    <BrickWall cols={30} rows={100}>
      <main class="artistsPage">
        <header class="artistsHeader">
          <a class="backLink" href="/">← Home</a>
          <h1>Artists</h1>

          <div class="searchWrap">
            <label class="srOnly" for="artist-search">Search artists</label>
            <input
              id="artist-search"
              class="searchInput"
              type="search"
              placeholder="Search by name, studio number, medium, or keyword"
              autocomplete="off"
            />
          </div>
        </header>

        <section class="artistGrid" id="artist-grid">
          {artists.map((artist) => (
            <a
              class="artistCard"
              href={`/artists/${artist.id}`}
              data-search={artist.searchText}
              aria-label={`${artist.displayName}, studio ${artist.studioNumber}`}
            >
              <div class="artistThumbWrap">
                <img
                  src={artist.thumb}
                  alt={artist.displayName}
                  class="artistThumb"
                  loading="lazy"
                  decoding="async"
                />

                <div class="artistInfo">
                  <h2>{artist.displayName}</h2>
                </div>
              </div>
            </a>
          ))}
        </section>

        <p class="noResults" id="no-results" hidden>No artists matched that search.</p>
      </main>
    </BrickWall>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.querySelector("#artist-search");
        const cards = document.querySelectorAll(".artistCard");
        const noResults = document.querySelector("#no-results");

        function filterArtists() {
          if (!searchInput) return;

          const query = searchInput.value.trim().toLowerCase();
          let visible = 0;

          cards.forEach((card) => {
            const text = card.dataset.search || "";
            const match = text.includes(query);

            card.style.display = match ? "" : "none";

            if (match) visible++;
          });

          if (noResults) {
            noResults.hidden = visible !== 0;
          }
        }

        if (searchInput) {
          searchInput.addEventListener("input", filterArtists);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100%;
  }

  body {
    background: #E4A8CB;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  img {
    max-width: 100%;
  }
</style>

<style>
  .srOnly {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .artistsPage {
    position: relative;
    z-index: 2;
    width: min(1100px, 100%);
    margin: 0 auto;
    padding: 24px 20px 48px;
  }

  .artistsHeader {
    display: grid;
    gap: 16px;
    margin-bottom: 28px;
  }

  .backLink {
    width: fit-content;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.95rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
  }

  .backLink:hover {
    text-decoration: underline;
  }

  .artistsHeader h1 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
  }

  .searchWrap {
    max-width: 640px;
  }

  .searchInput {
    width: 100%;
    height: 52px;
    padding: 0 18px;
    border: none;
    border-radius: 0;
    font: inherit;
    font-size: 1rem;
    color: #111111;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  }

  .searchInput::placeholder {
    color: #555555;
  }

  .searchInput:focus {
    outline: 3px solid rgba(255, 255, 255, 0.85);
    outline-offset: 2px;
  }

  .artistGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
    align-items: start;
  }

  .artistCard {
    display: block;
    text-decoration: none;
    color: #111111;
    transition: transform 160ms ease;
  }

  .artistCard:hover {
    transform: translateY(-4px);
  }

  .artistCard:focus-visible {
    outline: 3px solid rgba(255, 255, 255, 0.95);
    outline-offset: 6px;
  }

  .artistThumbWrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.18;
    overflow: hidden;
    background: #d8d8d8;
  }

  .artistThumb {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .artistInfo {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 14px 14px 16px;
    text-align: center;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .artistInfo h2 {
    margin: 0;
    font-size: clamp(1rem, 1.25vw, 1.2rem);
    font-weight: 400;
    line-height: 1.1;
  }

  .noResults {
    margin: 24px 0 0;
    color: #ffffff;
    font-size: 1rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 1100px) {
    .artistGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 800px) {
    .artistGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .artistsPage {
      padding: 20px 16px 36px;
    }

    .artistGrid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .searchInput {
      height: 50px;
      font-size: 0.95rem;
    }

    .artistInfo h2 {
      font-size: 1.35rem;
    }
  }
</style>