---
import BrickWall from "../../components/BrickWall.astro";
import rawArtists from "../../data/artists.json";

type Artist = {
  id: string;
  additional_info?: string;
  studioNumber: number | string;
  display_name: string;
  social_label?: string;
  website?: string;
  art_type?: string;
  image: string;
  thumbs: string;
};

const artists = rawArtists as Artist[];

export async function getStaticPaths() {

  const sortedArtists = [...artists].sort((a, b) => {
    if (Number(a.studioNumber) !== Number(b.studioNumber)) {
      return Number(a.studioNumber) - Number(b.studioNumber);
    }

    return a.display_name.localeCompare(b.display_name);
  });

  return sortedArtists.map((artist, index) => ({
    params: { id: String(artist.id) },
    props: {
      artist,
      prevArtist: index > 0 ? sortedArtists[index - 1] : null,
      nextArtist: index < sortedArtists.length - 1 ? sortedArtists[index + 1] : null
    }
  }));
}

const {
  artist,
  prevArtist,
  nextArtist
} = Astro.props as {
  artist: Artist;
  prevArtist: Artist | null;
  nextArtist: Artist | null;
};

const socialLabel = artist.social_label?.trim() ?? "";
const socialUrl = artist.website?.trim() ?? "";
const hasSocial = socialLabel !== "" && socialUrl !== "";
---

<html lang="en">

<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{artist.display_name} • Artists</title>
</head>

<body>

<BrickWall cols={30} rows={100}>

<main class="artistPage">

<a class="backLink" href="/artists">← Back to artists</a>

<div class="artistCard">

<img
src={artist.image}
alt={artist.display_name}
class="artistImage"
loading="eager"
decoding="async"
/>

<div class="artistDetails">

<h1>{artist.display_name}</h1>

<p class="studio">Studio {artist.studioNumber}</p>

{artist.art_type && (
<p class="medium">{artist.art_type}</p>
)}

{artist.additional_info && (
<p class="additionalInfo">{artist.additional_info}</p>
)}

{hasSocial && (
<a
href={socialUrl}
target="_blank"
rel="noopener noreferrer"
class="social"
>
{socialLabel}
</a>
)}

</div>

</div>

<nav class="artistNav">

<div class="navPrev">
{prevArtist && (
<a href={`/artists/${prevArtist.id}`}>
← {prevArtist.display_name}
</a>
)}
</div>

<div class="navNext">
{nextArtist && (
<a href={`/artists/${nextArtist.id}`}>
{nextArtist.display_name} →
</a>
)}
</div>

</nav>

</main>

</BrickWall>

</body>
</html>

<style is:global>

html, body {
margin:0;
padding:0;
min-height:100%;
}

body {
background:#E4A8CB;
font-family: Helvetica, Arial, sans-serif;
}

*,
*::before,
*::after {
box-sizing:border-box;
}

img {
max-width:100%;
display:block;
}

</style>

<style>

.artistPage {
position:relative;
z-index:2;
width:min(900px,100%);
margin:0 auto;
padding:40px 20px 60px;
}

.backLink {
color:white;
text-decoration:none;
font-size:0.9rem;
text-shadow:0 2px 10px rgba(0,0,0,0.25);
}

.backLink:hover {
text-decoration:underline;
}

.artistCard {
margin-top:20px;
}

.artistImage {
width:100%;
height:auto;
}

.artistDetails {
margin-top:0;
background:rgba(255,255,255,0.9);
padding:30px;
text-align:center;
}

.artistDetails h1 {
margin:0 0 10px;
font-size:clamp(2rem,3vw,2.6rem);
font-weight:400;
}

.studio {
margin:0;
font-size:1.2rem;
}

.medium {
margin:12px 0 0;
font-size:1rem;
line-height:1.4;
}

.additionalInfo {
margin:12px 0 0;
font-size:1rem;
line-height:1.4;
}

.social {
display:inline-block;
margin-top:16px;
font-size:1rem;
color:#111;
text-decoration:none;
}

.social:hover {
text-decoration:underline;
}

.artistNav {
margin-top:40px;
display:flex;
justify-content:space-between;
gap:20px;
color:white;
text-shadow:0 2px 10px rgba(0,0,0,0.25);
}

.artistNav a {
color:white;
text-decoration:none;
font-size:0.95rem;
}

.artistNav a:hover {
text-decoration:underline;
}

.navPrev {
text-align:left;
}

.navNext {
text-align:right;
}

@media (max-width:700px) {

.artistPage {
padding:24px 16px 40px;
}

.artistDetails {
padding:22px 18px;
}

.artistNav {
flex-direction:column;
gap:12px;
}

.navPrev,
.navNext {
text-align:left;
}

}

</style>