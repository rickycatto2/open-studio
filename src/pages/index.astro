---
const windows = [
  { title: "", bg: "/assets/window_food.svg", isStatic: true },
  { title: "", bg: "/assets/window_date.svg", isStatic: true },
  { title: "Artists", href: "/artists", bg: "/assets/window_artists.svg" },

  { title: "Entertainment", href: "/entertainment", bg: "/assets/window_entertainment.svg" },
  { title: "Parking", href: "/parking", bg: "/assets/window_parking.svg" },
  { title: "Connect", href: "/connect", bg: "/assets/window_subscribe.svg" },

  { title: "", bg: "/assets/sponsor1.png", isStatic: true },
  { title: "", bg: "/assets/sponsor2.png", isStatic: true },
  { title: "", bg: "/assets/sponsor3.png", isStatic: true },
  { title: "", bg: "/assets/sponsor4.png", isStatic: true },
  { title: "", bg: "/assets/sponsor5.png", isStatic: true },
  { title: "", bg: "/assets/sponsor6.png", isStatic: true }
];
---

<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Livestock Exchange Open Studios | Spring 2026</title>
</head>

<body>

<div class="brickOverlay">

  <div class="darkStream streamA"></div>
  <div class="darkStream streamB"></div>
  <div class="darkStream streamC"></div>
  <div class="darkStream streamD"></div>
  <div class="darkStream streamE"></div>
  <div class="darkStream streamF"></div>
  <div class="darkStream streamG"></div>

  <div class="eyeBrick eyeBrickOne">
    <div class="eye left-eye eye-a"><div class="pupil pupil-a"></div></div>
    <div class="eye right-eye eye-b"><div class="pupil pupil-b"></div></div>
  </div>

  <div class="eyeBrick eyeBrickTwo">
    <div class="eye left-eye eye-c"><div class="pupil pupil-c"></div></div>
    <div class="eye right-eye eye-d"><div class="pupil pupil-d"></div></div>
  </div>

</div>

<div class="pageShell">

<main class="home">

<section class="windowGrid">

{windows.map((w) =>
  w.isStatic ? (
    <div class="windowTile">
      <div class="windowShell">
        <img src={w.bg} class="windowLayer windowBackground" />
        <img src="/assets/window_frame.svg" class="windowLayer windowFrame" />
      </div>
    </div>
  ) : (
    <a class="windowTile windowLink" href={w.href}>
      <div class="windowShell">
        <img src={w.bg} class="windowLayer windowBackground" />
        <img src="/assets/window_frame.svg" class="windowLayer windowFrame" />
      </div>
    </a>
  )
)}

</section>

<footer class="siteFooter">

<div class="footerShell">

<img src="/assets/footer_truck.png" class="footerTruck"/>

<img src="/assets/footer_rotate.svg" class="footerRotate"/>

<a href="https://lauren-taylor-design.com/" class="footerLink linkLauren"></a>

<a href="https://rickycatto.com/" class="footerLink linkRicky"></a>

</div>

</footer>

</main>
</div>

</body>
</html>

<style>

body{
--brick-w:120px;
--brick-h:80px;

margin:0;
background:url("/assets/brick-base.svg") repeat;
background-size:var(--brick-w) auto;
background-color:#c44b3c;
}

.brickOverlay{
position:absolute;
inset:0;
pointer-events:none;
z-index:1;
}

.darkStream{
position:absolute;
top:0;
bottom:0;
width:var(--brick-w);
background:url("/assets/dark-brick.svg") repeat-y;
background-size:var(--brick-w) var(--brick-h);
}

/* staggered brick streams */

.streamA{left:calc(2*var(--brick-w));background-position:0 calc(1*var(--brick-h));}
.streamB{left:calc(4*var(--brick-w));background-position:0 calc(4*var(--brick-h));}
.streamC{left:calc(5*var(--brick-w));background-position:0 calc(2*var(--brick-h));}
.streamD{left:calc(7*var(--brick-w));background-position:0 calc(6*var(--brick-h));}
.streamE{left:calc(9*var(--brick-w));background-position:0 calc(3*var(--brick-h));}
.streamF{left:calc(11*var(--brick-w));background-position:0 calc(5*var(--brick-h));}
.streamG{left:calc(13*var(--brick-w));background-position:0 calc(1*var(--brick-h));}

/* eye bricks */

.eyeBrick{
position:absolute;
width:var(--brick-w);
height:var(--brick-h);
background:url("/assets/dark-brick.svg") no-repeat;
background-size:100% 100%;
z-index:2;
overflow:hidden;
}

.eyeBrickOne{
left:calc(0*var(--brick-w));
top:calc(3*var(--brick-h));
}

.eyeBrickTwo{
left:calc(8*var(--brick-w));
top:calc(4*var(--brick-h));
}

/* eyes */

.eye{
position:absolute;
top:8px;
width:23px;
height:23px;
border-radius:50%;
background:#ef654e;
overflow:hidden;
}

.left-eye{left:10px;}
.right-eye{left:52px;}

.pupil{
position:absolute;
left:8px;
top:8px;
width:11px;
height:11px;
border-radius:50%;
background:#8e382d;
}

/* blink */

@keyframes blink{
0%,48%,50%,100%{transform:scaleY(1)}
49%{transform:scaleY(.1)}
}

.eye-a,.eye-c{animation:blink 9s infinite;}
.eye-b,.eye-d{animation:blink 11s infinite;}

.pageShell{
position:relative;
z-index:5;
display:flex;
justify-content:center;
padding:30px;
}

.home{
max-width:1120px;
width:100%;
display:flex;
flex-direction:column;
gap:30px;
}

.windowGrid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:28px;
}

.windowShell{
position:relative;
aspect-ratio:270.782/377.165;
}

.windowLayer{
position:absolute;
inset:0;
width:100%;
height:100%;
}

.windowFrame{z-index:3;}

.siteFooter{
display:flex;
justify-content:center;
}

.footerShell{
position:relative;
width:min(720px,95vw);
}

.footerRotate{
position:absolute;
left:74%;
top:50%;
width:20%;
animation:spinTruck 28s linear infinite;
}

@keyframes spinTruck{
from{transform:rotate(0deg)}
to{transform:rotate(360deg)}
}

.linkLauren{
position:absolute;
left:37%;
top:60%;
width:26%;
height:11%;
}

.linkRicky{
position:absolute;
left:37%;
top:70%;
width:26%;
height:11%;
}

@media(max-width:900px){

.windowGrid{
grid-template-columns:1fr;
width:340px;
}

.streamA{left:calc(1*var(--brick-w))}
.streamB{left:calc(2*var(--brick-w))}
.streamC{left:calc(3*var(--brick-w))}
.streamD{left:calc(4*var(--brick-w))}
.streamE{left:calc(0*var(--brick-w))}
.streamF,.streamG{display:none}

}

@media(max-width:720px){

body{
--brick-w:92px;
--brick-h:61.3333px;
}

.eye{
top:6px;
width:18px;
height:18px;
}

.left-eye{left:7px}
.right-eye{left:34px}

.pupil{
left:6px;
top:6px;
width:9px;
height:9px;
}

}

</style>