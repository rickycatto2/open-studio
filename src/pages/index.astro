---
const windows = [
  { title: "", bg: "/assets/window_food.svg", isStatic: true },
  { title: "", bg: "/assets/window_date.svg", isStatic: true },
  { title: "Artists", href: "/artists", bg: "/assets/window_artists.svg" },

  { title: "Entertainment", href: "/entertainment", bg: "/assets/window_entertainment.svg" },
  { title: "Parking", href: "/parking", bg: "/assets/window_parking.svg" },
  { title: "Connect", href: "/connect", bg: "/assets/window_subscribe.svg" },

  { title: "", bg: "/assets/sponsor1.png", isStatic: true },
  { title: "", bg: "/assets/sponsor2.png", isStatic: true },
  { title: "", bg: "/assets/sponsor3.png", isStatic: true },
  { title: "", bg: "/assets/sponsor4.png", isStatic: true },
  { title: "", bg: "/assets/sponsor5.png", isStatic: true },
  { title: "", bg: "/assets/sponsor6.png", isStatic: true }
];
---

<html lang="en">
  <head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>Livestock Exchange Open Studios | Spring 2026</title>
  <meta name="description" content="Open studios at the historic Livestock Exchange Building in Kansas City. Meet the artists, see studios, enjoy entertainment and food." />

  <!-- Open Graph (link previews) -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Livestock Exchange Open Studios | Spring 2026" />
  <meta property="og:description" content="Open studios at the historic Livestock Exchange Building in Kansas City." />
  <meta property="og:url" content="https://stockyards.studio/" />
  <meta property="og:image" content="https://stockyards.studio/social-share.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Livestock Exchange Open Studios | Spring 2026" />
  <meta name="twitter:description" content="Open studios at the historic Livestock Exchange Building in Kansas City." />
  <meta name="twitter:image" content="https://stockyards.studio/social-share.jpg" />

  <!-- Optional but nice -->
  <link rel="canonical" href="https://stockyards.studio/" />
</head>

  <body>
    <div class="pageShell">
      <div class="wallDecor" aria-hidden="true">
        <div class="darkPattern"></div>

        <div class="eyeBrick eyeBrickOne">
          <div class="eye left-eye blink-a">
            <div class="pupil look-a"></div>
          </div>
          <div class="eye right-eye blink-b">
            <div class="pupil look-b"></div>
          </div>
        </div>
      </div>

      <main class="home">
        <section class="windowGrid" aria-label="Site sections">
          {windows.map((w) =>
            w.isStatic ? (
              <div class="windowTile windowTileStatic" aria-hidden="true">
                <div class="windowShell">
                  <img
                    src={w.bg}
                    alt=""
                    class="windowLayer windowBackground"
                    loading="eager"
                    decoding="async"
                  />
                  <img
                    src="/assets/window_frame.svg"
                    alt=""
                    class="windowLayer windowFrame"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              </div>
            ) : (
              <a class="windowTile windowLink" href={w.href} aria-label={w.title}>
                <div class="windowShell">
                  <img
                    src={w.bg}
                    alt=""
                    class="windowLayer windowBackground"
                    loading="eager"
                    decoding="async"
                  />
                  <img
                    src="/assets/window_frame.svg"
                    alt=""
                    class="windowLayer windowFrame"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              </a>
            )
          )}
        </section>

        <footer class="siteFooter" aria-label="Credits">
          <div class="footerShell">
            <img
              src="/assets/footer_truck.png"
              alt=""
              class="footerTruck"
              loading="eager"
              decoding="async"
            />

            <img
              src="/assets/footer_rotate.svg"
              alt=""
              class="footerRotate"
              aria-hidden="true"
              loading="eager"
              decoding="async"
            />

            <a
              href="https://lauren-taylor-design.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="footerLink linkLauren"
              aria-label="Lauren Taylor Website"
            ></a>

            <a
              href="https://rickycatto.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="footerLink linkRicky"
              aria-label="Ricky Catto Website"
            ></a>
          </div>
        </footer>
      </main>
    </div>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html, body) {
    margin: 0;
    padding: 0;
    min-height: 100%;
    font-family: Arial, Helvetica, sans-serif;
  }

  body {
    --brick-w: 120px;
    --brick-h: 80px;

    margin: 0;
    min-height: 100vh;
    background-image: url("/assets/brick-base.svg");
    background-repeat: repeat;
    background-size: var(--brick-w) auto;
    background-position: top left;
    background-color: #c44b3c;
  }

  :global(img) {
    max-width: 100%;
  }

  .pageShell {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    padding: 28px 16px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wallDecor {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .darkPattern {
    position: absolute;
    inset: 0;
    background-image:
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg"),
      url("/assets/dark-brick.svg");
    background-repeat:
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat,
      no-repeat;
    background-size:
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h),
      var(--brick-w) var(--brick-h);
    background-position:
      calc(2 * var(--brick-w))  calc(0 * var(--brick-h)),
      calc(5 * var(--brick-w))  calc(2 * var(--brick-h)),
      calc(8 * var(--brick-w))  calc(1 * var(--brick-h)),
      calc(11 * var(--brick-w)) calc(3 * var(--brick-h)),
      calc(1 * var(--brick-w))  calc(6 * var(--brick-h)),
      calc(4 * var(--brick-w))  calc(8 * var(--brick-h)),
      calc(9 * var(--brick-w))  calc(7 * var(--brick-h)),
      calc(12 * var(--brick-w)) calc(9 * var(--brick-h)),
      calc(3 * var(--brick-w))  calc(12 * var(--brick-h)),
      calc(7 * var(--brick-w))  calc(14 * var(--brick-h)),
      calc(10 * var(--brick-w)) calc(13 * var(--brick-h)),
      calc(0 * var(--brick-w))  calc(16 * var(--brick-h)),
      calc(6 * var(--brick-w))  calc(18 * var(--brick-h)),
      calc(11 * var(--brick-w)) calc(20 * var(--brick-h));
  }

  .eyeBrick {
    position: absolute;
    width: var(--brick-w);
    height: var(--brick-h);
    background-image: url("/assets/dark-brick.svg");
    background-repeat: no-repeat;
    background-size: 100% 100%;
    overflow: hidden;
    z-index: 2;
  }

  .eyeBrickOne {
    left: calc(0 * var(--brick-w));
    top: calc(4 * var(--brick-h));
  }

  .eye {
    position: absolute;
    top: 8px;
    width: 23px;
    height: 23px;
    border-radius: 50%;
    background: #ef654e;
    overflow: hidden;
    transform-origin: center center;
  }

  .left-eye {
    left: 10px;
  }

  .right-eye {
    left: 52px;
  }

  .pupil {
    position: absolute;
    left: 6px;
    top: 6px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #8e382d;
  }

  @keyframes blinkA {
    0%, 46%, 48%, 84%, 86%, 100% { transform: scaleY(1); }
    47%, 85% { transform: scaleY(0.08); }
  }

  @keyframes blinkB {
    0%, 28%, 30%, 72%, 74%, 100% { transform: scaleY(1); }
    29%, 73% { transform: scaleY(0.08); }
  }

  @keyframes lookA {
    0%, 10%, 24%, 40%, 58%, 76%, 100% { transform: translate(0, 0); }
    14%, 20% { transform: translate(5px, -1px); }
    46%, 54% { transform: translate(-5px, 1px); }
    82%, 90% { transform: translate(3px, 1px); }
  }

  @keyframes lookB {
    0%, 12%, 26%, 44%, 60%, 78%, 100% { transform: translate(0, 0); }
    16%, 22% { transform: translate(-5px, 0); }
    50%, 56% { transform: translate(4px, 2px); }
    84%, 90% { transform: translate(1px, -2px); }
  }

  .blink-a { animation: blinkA 8.8s infinite; }
  .blink-b { animation: blinkB 11.1s infinite; }

  .look-a { animation: lookA 6.8s infinite ease-in-out; }
  .look-b { animation: lookB 7.5s infinite ease-in-out; }

  .home {
    position: relative;
    z-index: 5;
    min-height: 100vh;
    width: 100%;
    max-width: 1120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .windowGrid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px 24px;
    justify-items: center;
    align-items: center;
  }

  .windowTile {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .windowLink {
    text-decoration: none;
    transition: transform 160ms ease;
  }

  .windowLink:hover {
    transform: translateY(-4px);
  }

  .windowShell {
    position: relative;
    width: min(100%, 320px);
    aspect-ratio: 270.782 / 377.165;
  }

  .windowLayer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .windowBackground {
    z-index: 1;
  }

  .windowFrame {
    z-index: 3;
    pointer-events: none;
  }

  .siteFooter {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: auto;
  }

  .footerShell {
    position: relative;
    width: min(720px, 95vw);
    line-height: 0;
  }

  .footerTruck {
    display: block;
    width: 100%;
    height: auto;
  }

  .footerRotate {
    position: absolute;
    left: 74%;
    top: 50%;
    width: 20%;
    height: auto;
    transform-origin: center center;
    animation: spinTruck 28s linear infinite;
    pointer-events: none;
  }

  @keyframes spinTruck {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .footerLink {
    position: absolute;
    display: block;
  }

  .linkLauren {
    left: 37%;
    top: 60%;
    width: 26%;
    height: 11%;
    transform: translateY(30px);
  }

  .linkRicky {
    left: 37%;
    top: 70%;
    width: 26%;
    height: 11%;
    transform: translateY(30px);
  }

  .footerLink:hover {
    cursor: pointer;
  }

  @media (min-width: 720px) {
    .pageShell {
      padding: 36px 24px 0;
    }
  }

  @media (max-width: 900px) {
    .home {
      gap: 24px;
    }

    .windowGrid {
      width: min(340px, 100%);
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .footerShell {
      width: min(520px, 95vw);
    }

    .darkPattern {
      background-image:
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg"),
        url("/assets/dark-brick.svg");
      background-repeat:
        no-repeat,
        no-repeat,
        no-repeat,
        no-repeat,
        no-repeat,
        no-repeat,
        no-repeat,
        no-repeat;
      background-size:
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h),
        var(--brick-w) var(--brick-h);
      background-position:
        calc(1 * var(--brick-w)) calc(0 * var(--brick-h)),
        calc(3 * var(--brick-w)) calc(2 * var(--brick-h)),
        calc(0 * var(--brick-w)) calc(7 * var(--brick-h)),
        calc(4 * var(--brick-w)) calc(9 * var(--brick-h)),
        calc(2 * var(--brick-w)) calc(11 * var(--brick-h)),
        calc(1 * var(--brick-w)) calc(15 * var(--brick-h)),
        calc(3 * var(--brick-w)) calc(18 * var(--brick-h)),
        calc(0 * var(--brick-w)) calc(21 * var(--brick-h));
    }

    .eyeBrickOne {
      left: calc(0 * var(--brick-w));
      top: calc(4 * var(--brick-h));
    }
  }

  @media (max-width: 720px) {
    body {
      --brick-w: 92px;
      --brick-h: 61.3333px;
    }

    .pageShell {
      padding: 18px 12px 0;
    }

    .eye {
      top: 6px;
      width: 18px;
      height: 18px;
    }

    .left-eye {
      left: 7px;
    }

    .right-eye {
      left: 34px;
    }

    .pupil {
      left: 4px;
      top: 4px;
      width: 9px;
      height: 9px;
    }
  }
</style>