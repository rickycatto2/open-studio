---
const socialLinks = [
  {
    label: "Instagram",
    url: "https://www.instagram.com/stockyards_studios/"
  },
  {
    label: "Facebook",
    url: "https://www.facebook.com/stockyardsstudios"
  },
  {
    label: "Facebook Event",
    url: "https://www.facebook.com/share/1CJmakiZ3z/"
  }
];

const partners = [
  { name: "DMH", url: "https://wearedmh.com/" },
  { name: "George Interiors", url: "https://georgeterbovichdesign.com/" },
  {
    name: "Blick Art Materials",
    url: "https://www.dickblick.com/stores/missouri/kansas-city/"
  },
  { name: "Josh Dampf Events", url: "https://www.joshdampf.com/" },
  { name: "Design Spout", url: "https://design-spout.com/" },
  { name: "No Divide", url: "https://www.nodividekc.org/" },
  { name: "Amigoni Urban Winery", url: "https://amigoni.com/" },
  { name: "Stockyards Brewery", url: "https://stockyardsbrewing.com/" },
  { name: "FS&L Architects", url: "https://fslarch.com/" },
  { name: "Hoxie Collective LLC", url: "https://www.hoxiecollective.com/" },
  { name: "Heather & Jason Kort" },
  { name: "Regina Kort" },
  { name: "Trilling Family in memory of Gerry Trilling" }
];

const linkedPartners = partners.filter((partner) => partner.url);
const plainPartners = partners.filter((partner) => !partner.url);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Connect</title>
    <meta
      name="description"
      content="Follow updates, subscribe by email, and meet our support partners."
    />
  </head>

  <body>
    <div class="pageShell">
      <div class="navRow">
        <a href="/" class="backButton">← Home</a>
      </div>

      <main class="poster">
        <header class="posterHeader">
          <p class="eyebrow">Open Studios</p>
          <h1>Connect</h1>
          <p class="intro">
            Follow along, subscribe for updates, and meet the support partners
            helping make this event happen.
          </p>
        </header>

        <div class="contentGrid">
          <section class="infoSection">
            <div class="sectionBanner">
              <h2>Follow</h2>
            </div>

            <div class="cardStack">
              {socialLinks.map((link) => (
                <article class="infoCard">
                  <h3>{link.label}</h3>
                  <p class="description">
                    Visit our {link.label.toLowerCase()} for updates, reminders,
                    and event info.
                  </p>
                  <p class="linkWrap">
                    <a href={link.url} target="_blank" rel="noreferrer">
                      Open {link.label}
                    </a>
                  </p>
                </article>
              ))}
            </div>
          </section>

          <section class="infoSection">
            <div class="sectionBanner">
              <h2>Email Updates</h2>
            </div>

            <article class="infoCard subscribeCard">
              <h3>Subscribe by Email</h3>
              <p class="description">
                Pop your email in below to get updates, reminders, and useful event
                info.
              </p>

              <form
                class="subscribeForm"
                action="https://gmail.us10.list-manage.com/subscribe/post?u=3525bc362fd1de19decab8e62&id=0d5cdc3b1b&f_id=004dd0e3f0"
                method="post"
                target="_blank"
                novalidate
              >
                <label class="srOnly" for="mce-EMAIL">Email address</label>
                <input
                  id="mce-EMAIL"
                  type="email"
                  name="EMAIL"
                  placeholder="Email address"
                  required
                />

                <button type="submit" name="subscribe" value="Subscribe">
                  Subscribe
                </button>

                <input
                  type="text"
                  name="b_3525bc362fd1de19decab8e62_0d5cdc3b1b"
                  tabindex="-1"
                  value=""
                  aria-hidden="true"
                  autocomplete="off"
                  style="position:absolute !important; left:-5000px !important; top:auto !important; width:1px !important; height:1px !important; overflow:hidden !important; opacity:0 !important; pointer-events:none !important;"
                />
              </form>

              <p class="formNote">
                Subscribe for email updates, reminders, and event info.
              </p>
            </article>
          </section>

          <section class="infoSection partnerSection">
            <div class="sectionBanner">
              <h2>Support Partners</h2>
            </div>

            <div class="partnerGrid" data-partners>
              {linkedPartners.map((partner) => (
                <a
                  class="partnerCard partnerLink"
                  href={partner.url}
                  target="_blank"
                  rel="noreferrer"
                >
                  <span>{partner.name}</span>
                </a>
              ))}

              {plainPartners.map((partner) => (
                <div class="partnerCard partnerStatic">
                  <span>{partner.name}</span>
                </div>
              ))}
            </div>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html, body) {
    margin: 0;
    padding: 0;
    min-height: 100%;
    font-family: Arial, Helvetica, sans-serif;
    color: #132033;
  }

  body {
    min-height: 100vh;
    background-image: url("/assets/brick-base.svg");
    background-repeat: repeat;
    background-size: 120px auto;
    background-position: top left;
    background-color: #c44b3c;
  }

  .pageShell {
    width: 100%;
    min-height: 100vh;
    padding: 28px 16px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .navRow {
    width: min(100%, 980px);
    margin-bottom: 12px;
    display: flex;
    justify-content: flex-start;
  }

  .backButton {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255, 244, 184, 0.96);
    color: #1f1a17;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .backButton:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.2);
    background: #fff2a8;
  }

  .poster {
    width: min(980px, 100%);
    background: rgba(255, 248, 220, 0.94);
    border: 4px solid #132033;
    border-radius: 28px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
    overflow: hidden;
    backdrop-filter: blur(2px);
  }

  .posterHeader {
    padding: 1.2rem 1.5rem 2rem;
    text-align: center;
    background:
      radial-gradient(circle at top, rgba(255, 225, 90, 0.6), transparent 55%),
      linear-gradient(180deg, #ffe35c 0%, #ffd23a 100%);
    border-bottom: 4px solid #132033;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .posterHeader h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .intro {
    max-width: 42rem;
    margin: 1rem auto 0;
    font-size: 1rem;
    line-height: 1.5;
  }

  .contentGrid {
    padding: 1.5rem;
    display: grid;
    gap: 2rem;
  }

  .infoSection {
    display: grid;
    gap: 1rem;
  }

  .sectionBanner {
    background: #132033;
    color: #fff7c7;
    padding: 0.9rem 1.1rem;
    border-radius: 18px;
    box-shadow: 0 6px 0 #ffd23a;
  }

  .sectionBanner h2 {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.9rem);
    line-height: 1.1;
    text-transform: uppercase;
  }

  .cardStack {
    display: grid;
    gap: 1rem;
  }

  .infoCard {
    padding: 1rem 1.1rem;
    background: rgba(255, 255, 255, 0.9);
    border: 3px solid #132033;
    border-radius: 22px;
    box-shadow: 0 8px 0 rgba(19, 32, 51, 0.12);
  }

  .infoCard h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .description {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .linkWrap {
    margin: 0.8rem 0 0;
  }

  .linkWrap a {
    color: #132033;
    font-weight: 700;
    text-decoration-thickness: 2px;
  }

  .subscribeCard {
    background:
      linear-gradient(180deg, rgba(196, 239, 255, 0.9), rgba(255, 255, 255, 0.95));
    position: relative;
  }

  .subscribeForm {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    position: relative;
  }

  .subscribeForm input[type="email"] {
    width: 100%;
    min-width: 0;
    padding: 0.9rem 1rem;
    border: 2px solid #132033;
    border-radius: 999px;
    font: inherit;
    background: #fffdf4;
    color: #132033;
  }

  .subscribeForm button {
    border: 2px solid #132033;
    border-radius: 999px;
    padding: 0.9rem 1.2rem;
    font: inherit;
    font-weight: 700;
    background: #ffe35c;
    color: #132033;
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    white-space: nowrap;
  }

  .subscribeForm button:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.14);
    background: #ffd23a;
  }

  .formNote {
    margin: 0.8rem 0 0;
    font-size: 0.82rem;
    line-height: 1.4;
    opacity: 0.72;
  }

  .partnerSection {
    padding-bottom: 0.25rem;
  }

  .partnerGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .partnerCard {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 96px;
    padding: 1rem;
    text-align: center;
    color: #132033;
    font-weight: 700;
    background:
      linear-gradient(180deg, rgba(255, 233, 188, 0.92), rgba(255, 255, 255, 0.92));
    border: 3px solid #132033;
    border-radius: 22px;
    box-shadow: 0 8px 0 rgba(19, 32, 51, 0.12);
  }

  .partnerLink {
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .partnerLink:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 0 rgba(19, 32, 51, 0.16);
  }

  .partnerStatic {
    opacity: 0.95;
  }

  .srOnly {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 720px) {
    .pageShell {
      padding: 36px 24px 72px;
    }
  }

  @media (max-width: 720px) {
    body {
      background-size: 92px auto;
    }

    .pageShell {
      padding: 18px 12px 48px;
    }

    .navRow {
      margin-bottom: 10px;
    }

    .backButton {
      font-size: 0.9rem;
      padding: 9px 14px;
    }

    .poster {
      border-width: 3px;
      border-radius: 20px;
    }

    .posterHeader {
      padding: 1rem 1rem 1.6rem;
    }

    .posterHeader h1 {
      font-size: clamp(1.8rem, 8vw, 2.8rem);
    }

    .intro {
      font-size: 0.95rem;
    }

    .contentGrid {
      padding: 1rem;
      gap: 1.25rem;
    }

    .sectionBanner h2 {
      font-size: 1.1rem;
    }

    .infoCard h3 {
      font-size: 1.15rem;
    }

    .description,
    .formNote {
      font-size: 0.92rem;
    }

    .subscribeForm {
      grid-template-columns: 1fr;
    }

    .subscribeForm button {
      width: 100%;
    }

    .partnerGrid {
      grid-template-columns: 1fr 1fr;
      gap: 0.85rem;
    }

    .partnerCard {
      min-height: 82px;
      border-radius: 18px;
    }
  }
</style>