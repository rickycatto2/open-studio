---
import BaseLayout from "../layouts/BaseLayout.astro";
import WindowSVG from "../components/WindowSVG.astro";
import CatSillSVG from "../components/CatSillSVG.astro";
import sponsors from "../data/sponsors.json";

const windows = [
  { title: "Artists", href: "/artists", hint: "Search directory" },
  { title: "Parking", href: "/parking", hint: "Map + tips" },
  { title: "Entertainment", href: "/entertainment", hint: "Schedule" },
  { title: "Food", href: "/food", hint: "Vendors" },
  { title: "Subscribe", href: "/subscribe", hint: "Newsletter" },
  { title: "Sponsors", href: "/sponsors", hint: "Thanks!" }
];
---

<BaseLayout title="Open Studios • Home">
  <div class="grid">
    {windows.map((w, i) => (
      <a class="windowLink" href={w.href} aria-label={w.title}>
        <WindowSVG title={w.title} />
        {/* Put the cat only on the first window as a fun accent (change as you like) */}
        {i === 0 && <CatSillSVG />}
        <div class="windowLabel">
          <span>{w.title}</span>
          <small>{w.hint}</small>
        </div>
      </a>
    ))}
  </div>

  <div class="footerSponsors">
    <strong>Sponsors:</strong>
    {sponsors.map(s => <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>)}
  </div>
</BaseLayout>