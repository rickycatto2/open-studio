---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Subscribe • Open Studios">
  <div class="card">
    <h2 style="margin-top:0">Subscribe to our email newsletter</h2>
    <p>This can be Mailchimp, Buttondown, ConvertKit, etc. For POC, here’s a placeholder form.</p>

    <form onsubmit="event.preventDefault(); alert('Pretend this subscribed you. (We’ll wire it to a real provider next.)');">
      <div class="searchRow">
        <input type="email" required placeholder="you@domain.com" />
        <button type="submit" style="padding:10px 14px;border-radius:12px;border:1px solid rgba(17,24,39,0.15);font-weight:800;">
          Subscribe
        </button>
      </div>
      <small style="color:rgba(17,24,39,0.65)">No spam. Just event updates and artist highlights.</small>
    </form>
  </div>
</BaseLayout>